# Application
CORTEXFLOW_ENV=development
CORTEXFLOW_DEBUG=false
CORTEXFLOW_HOST=0.0.0.0
CORTEXFLOW_PORT=8000

# Database
CORTEXFLOW_DB_URL=sqlite:///./data/cortexflow.db

# Auth
CORTEXFLOW_SECRET_KEY=change-me-in-production-use-secure-random
CORTEXFLOW_TOKEN_EXPIRY_HOURS=24

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Google
GOOGLE_API_KEY=

# Xiaomi MiMo
MIMO_API_KEY=
MIMO_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434

# Default provider (anthropic, openai, google, mimo, ollama)
CORTEXFLOW_DEFAULT_PROVIDER=mimo

# Plugins
CORTEXFLOW_PLUGINS_DIR=./plugins
CORTEXFLOW_PLUGINS_AUTOLOAD=true

# Token tracking
CORTEXFLOW_TOKEN_ALERT_THRESHOLD=1000000
CORTEXFLOW_TOKEN_MONTHLY_BUDGET=50000000

# Concurrency
CORTEXFLOW_MAX_CONCURRENT_JOBS=10
